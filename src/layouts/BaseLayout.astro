---
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/nav.css';
import '../styles/layout.css';

import Nav from '../components/Nav.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const { title = 'LightHouse', description = 'LightHouse 学习资料库 — 探索、学习、创造', pageClass = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title === 'LightHouse' ? title : `${title} | LightHouse`}</title>
  <link rel="icon" href={`${base}lighthouse-icon.svg`} />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@300;400;500;700&family=Shippori+Mincho:wght@600&display=swap" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha384-nB0miv6/jRmo5OLARBER7sSEMTuN/lKRqq4dEy8OH7LLwlBGfJcEDGOsKuX8EGHo" crossorigin="anonymous" />
  <ClientRouter />
  <script is:inline>
    // Dark mode initialization - runs before paint to avoid flash
    (function() {
      const saved = localStorage.getItem('lh-theme');
      if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
    // Preserve dark mode across ClientRouter navigations
    document.addEventListener('astro:before-swap', function(ev) {
      var isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        ev.newDocument.documentElement.classList.add('dark');
      } else {
        ev.newDocument.documentElement.classList.remove('dark');
      }
    });
  </script>
</head>
<body>
  <div class={pageClass}>
    <Nav />
    <slot />
  </div>
  <script is:inline>
    // Mermaid: render ```mermaid code blocks
    function initMermaid() {
      var blocks = document.querySelectorAll('pre > code.language-mermaid');
      if (!blocks.length) return;
      // Load mermaid from CDN
      if (!window.mermaid) {
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
        s.onload = function() {
          var isDark = document.documentElement.classList.contains('dark');
          window.mermaid.initialize({ startOnLoad: false, theme: isDark ? 'dark' : 'default' });
          renderMermaidBlocks(blocks);
        };
        document.head.appendChild(s);
      } else {
        renderMermaidBlocks(blocks);
      }
    }
    function renderMermaidBlocks(blocks) {
      blocks.forEach(function(code, i) {
        var pre = code.parentElement;
        var div = document.createElement('div');
        div.className = 'mermaid';
        div.textContent = code.textContent;
        pre.parentElement.replaceChild(div, pre);
      });
      window.mermaid.run();
    }
    // Run on initial load and after client-side navigation
    document.addEventListener('DOMContentLoaded', initMermaid);
    document.addEventListener('astro:page-load', initMermaid);
  </script>
</body>
</html>
