---
import '../styles/doc.css';
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import DocFooter from '../components/DocFooter.astro';
import ChatWidget from '../components/chat/ChatWidget.tsx';
import ReadingProgress from '../components/ReadingProgress.tsx';
import { getSidebarGroups } from '../data/sidebar';

interface Props {
  title?: string;
  headings?: { depth: number; slug: string; text: string }[];
  slug?: string;
  date?: string;
}

const { title = 'LightHouse', headings = [], slug = '', date } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sidebarGroups = getSidebarGroups(currentPath.replace(base, ''));
const hasSidebar = sidebarGroups !== null && sidebarGroups.length > 0;
const articleHeroBgs = [
  'bg1.png', 'bg2.png', 'bg3.jpg', 'bg4.webp', 'bg5.png', 'bg6.png', 'bg7.jpg', 'bg8.jpg', 'bg9.png', 'bg10.jpg',
  'bg11.png', 'bg12.png', 'bg13.png', 'bg14.png', 'bg15.png', 'bg16.png', 'bg17.png', 'bg18.png', 'bg19.png', 'bg20.png',
  'bg21.png', 'bg22.png', 'bg23.png', 'bg24.png', 'bg25.png', 'bg26.png', 'bg27.png', 'bg28.png', 'bg29.png', 'bg30.png',
  'bg31.png', 'bg32.png', 'bg33.png', 'bg34.png', 'bg35.png', 'bg36.png', 'bg37.png', 'bg38.png', 'bg39.png', 'bg40.png',
  'bg41.png', 'bg42.png', 'bg43.png', 'bg44.png', 'bg45.png', 'bg46.png', 'bg47.png', 'bg48.png', 'bg49.png', 'bg50.png',
  'bg51.png', 'bg52.png', 'bg53.png', 'bg54.png', 'bg55.png', 'bg56.png', 'bg57.png', 'bg58.png', 'bg59.png', 'bg60.png',
  'bg61.png', 'bg62.png', 'bg63.png', 'bg64.png', 'bg65.png',
];
const initialHeroBg = articleHeroBgs[Math.floor(Math.random() * articleHeroBgs.length)];
const cleanSlug = slug.replace(/\.md$/, '');
const slugSegments = cleanSlug.split('/').filter(Boolean);
const heroLabel = (() => {
  if (slugSegments[0] === 'ai-research' && slugSegments[1] === 'agent') return 'Agent';
  if (cleanSlug.startsWith('ai-product-analysis/news/')) return 'News';
  if (cleanSlug.startsWith('ai-product-analysis/')) return 'AI 产品分析';
  if (cleanSlug.startsWith('ai-research/')) return 'AI Research';
  if (cleanSlug.startsWith('unity-tutorial/')) return 'Unity';
  if (cleanSlug.startsWith('electron-tutorial/')) return 'Electron';
  if (cleanSlug.startsWith('rust-tutorial/')) return 'Rust';
  return 'LightHouse';
})();
---

<BaseLayout title={title} pageClass={`lh-page-doc${hasSidebar ? ' has-sidebar' : ''}`}>
  <main class="lh-main">
    {hasSidebar && sidebarGroups && (
      <Sidebar groups={sidebarGroups} currentPath={currentPath} />
    )}
    <div class="lh-main-content">
      <article class="lh-prose">
        <div class="lh-article-hero" style={`--lh-article-hero-bg: url('${base}/card-bg/${initialHeroBg}')`}>
          <div class="lh-article-hero-inner">
            <span class="lh-article-hero-label">{heroLabel}</span>
            <h1 class="lh-article-hero-title">{title}</h1>
          </div>
        </div>
        {date && (
          <div class="lh-article-date">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{date}</span>
          </div>
        )}
        <slot />
      </article>
      <DocFooter currentPath={currentPath} />
    </div>
    {headings.length > 0 && (
      <div class="lh-toc-wrap">
        <TableOfContents headings={headings} />
      </div>
    )}
  </main>
  <ReadingProgress client:only="react" slug={cleanSlug} title={title} />
  <ChatWidget client:only="react" />
</BaseLayout>

<script is:inline define:vars={{ base }}>
  (() => {
    const heroImages = [
      'bg1.png', 'bg2.png', 'bg3.jpg', 'bg4.webp', 'bg5.png', 'bg6.png', 'bg7.jpg', 'bg8.jpg', 'bg9.png', 'bg10.jpg',
      'bg11.png', 'bg12.png', 'bg13.png', 'bg14.png', 'bg15.png', 'bg16.png', 'bg17.png', 'bg18.png', 'bg19.png', 'bg20.png',
      'bg21.png', 'bg22.png', 'bg23.png', 'bg24.png', 'bg25.png', 'bg26.png', 'bg27.png', 'bg28.png', 'bg29.png', 'bg30.png',
      'bg31.png', 'bg32.png', 'bg33.png', 'bg34.png', 'bg35.png', 'bg36.png', 'bg37.png', 'bg38.png', 'bg39.png', 'bg40.png',
      'bg41.png', 'bg42.png', 'bg43.png', 'bg44.png', 'bg45.png', 'bg46.png', 'bg47.png', 'bg48.png', 'bg49.png', 'bg50.png',
      'bg51.png', 'bg52.png', 'bg53.png', 'bg54.png', 'bg55.png', 'bg56.png', 'bg57.png', 'bg58.png', 'bg59.png', 'bg60.png',
      'bg61.png', 'bg62.png', 'bg63.png', 'bg64.png', 'bg65.png',
    ];
    const applyRandomHero = () => {
      const hero = document.querySelector('.lh-article-hero');
      if (!hero) return;
      const randomImage = heroImages[Math.floor(Math.random() * heroImages.length)];
      hero.style.setProperty('--lh-article-hero-bg', `url('${base}/card-bg/${randomImage}')`);
    };

    applyRandomHero();

    if (!window.__lhArticleHeroRandomInited) {
      document.addEventListener('astro:page-load', applyRandomHero);
      window.__lhArticleHeroRandomInited = true;
    }
  })();
</script>
