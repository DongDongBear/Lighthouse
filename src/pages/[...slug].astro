---
import { getCollection } from 'astro:content';
import DocLayout from '../layouts/DocLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  const paths: { params: { slug: string }; props: { doc: (typeof docs)[number] } }[] = [];
  const seen = new Set<string>();

  docs
    .filter(doc => {
      const id = doc.id;
      // Skip README files
      if (id.endsWith('README.md') || id === 'README.md') return false;
      return true;
    })
    .forEach(doc => {
      let slug = doc.id.replace(/\.md$/, '');
      // "unity-tutorial/index" → "unity-tutorial"
      slug = slug.replace(/\/index$/, '');

      if (!seen.has(slug)) {
        paths.push({
          params: { slug },
          props: { doc },
        });
        seen.add(slug);
      }

      // Compatibility alias: "/section/readme" -> "/section/"
      if (doc.id.endsWith('/index.md')) {
        const readmeAlias = doc.id.replace(/\/index\.md$/, '/readme');
        if (!seen.has(readmeAlias)) {
          paths.push({
            params: { slug: readmeAlias },
            props: { doc },
          });
          seen.add(readmeAlias);
        }
      }
    });

  return paths;
}

const { doc } = Astro.props;
const { Content, headings } = await doc.render();

// Extract title from first h1 heading, or use slug
const h1 = headings.find(h => h.depth === 1);
const title = h1?.text || doc.id.split('/').pop()?.replace(/^\d+-/, '').replace(/-/g, ' ') || 'LightHouse';
const date = doc.data?.date || undefined;
---

<DocLayout title={title} headings={headings} slug={doc.id} date={date}>
  <Content />
</DocLayout>
