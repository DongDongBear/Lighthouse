---
import ThemeToggle from './ThemeToggle.tsx';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="lh-nav">
  <div class="lh-nav-left">
    <a class="lh-nav-logo" href={`${base}/`}>
      <svg class="lh-nav-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3l2 3l2 15h-8l2 -15l2 -3" />
        <path d="M8 9l8 0" />
        <path d="M3 11l2 -2l-2 -2" />
        <path d="M21 11l-2 -2l2 -2" />
      </svg>
      <span class="lh-nav-title">LightHouse</span>
    </a>
  </div>
  <div class="lh-nav-right">
    <ThemeToggle client:load />
    <button class="lh-nav-hamburger" id="sidebar-toggle" aria-label="打开菜单">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>
</header>
