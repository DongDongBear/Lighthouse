---
import '../styles/sidebar.css';
import type { SidebarGroup } from '../data/sidebar';

interface Props {
  groups: SidebarGroup[];
  currentPath: string;
}

const { groups, currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function isActive(link: string): boolean {
  const fullLink = `${base}${link}`;
  const normalized = currentPath.replace(/\/$/, '');
  const normalizedLink = fullLink.replace(/\/$/, '');
  return normalized === normalizedLink;
}

function groupHasActive(group: { items: { link?: string; items?: { link?: string }[] }[] }): boolean {
  return group.items.some(item =>
    (item.link && isActive(item.link)) ||
    (item.items && item.items.some(sub => sub.link && isActive(sub.link)))
  );
}
---

<div class="lh-sidebar-overlay" id="sidebar-overlay"></div>
<aside class="lh-sidebar" id="sidebar" transition:persist>
  <nav class="lh-sidebar-nav">
    {groups.map((group) => {
      const forceExpand = groupHasActive(group);
      const isCollapsed = forceExpand ? false : !!group.collapsed;
      return (
        <div class="lh-sidebar-group">
          <div class="lh-sidebar-group-title" data-collapsed={isCollapsed ? 'true' : 'false'}>
            <span>{group.text}</span>
            <svg class:list={['lh-sidebar-arrow', { collapsed: isCollapsed }]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </div>
          <ul class:list={['lh-sidebar-items', { collapsed: isCollapsed }]}>
            {group.items.map((item) => {
              const subHasActive = item.items?.some(sub => sub.link && isActive(sub.link)) ?? false;
              const subCollapsed = subHasActive ? false : !!item.collapsed;
              return (
              <li>
                {item.items ? (
                  <Fragment>
                    <div class="lh-sidebar-subgroup-title" data-collapsed={subCollapsed ? 'true' : 'false'}>
                      <span>{item.text}</span>
                      <svg class:list={['lh-sidebar-arrow', { collapsed: subCollapsed }]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="6 9 12 15 18 9" />
                      </svg>
                    </div>
                    <ul class:list={['lh-sidebar-subitems', { collapsed: subCollapsed }]}>
                      {item.items.map((sub) => (
                        <li>
                          {sub.link ? (
                            <a class:list={['lh-sidebar-link lh-sidebar-sublink', { active: isActive(sub.link) }]} href={`${base}${sub.link}`}>
                              {sub.text}
                            </a>
                          ) : (
                            <span class="lh-sidebar-link level-1">{sub.text}</span>
                          )}
                        </li>
                      ))}
                    </ul>
                  </Fragment>
                ) : item.link ? (
                  <a class:list={['lh-sidebar-link', { active: isActive(item.link) }]} href={`${base}${item.link}`}>
                    {item.text}
                  </a>
                ) : (
                  <span class="lh-sidebar-link level-0">{item.text}</span>
                )}
              </li>
            )})}
          </ul>
        </div>
      );
    })}
  </nav>
</aside>

<script>
  function initSidebar() {
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function openSidebar() {
      sidebar?.classList.add('open');
      overlay?.classList.add('visible');
    }

    function closeSidebar() {
      sidebar?.classList.remove('open');
      overlay?.classList.remove('visible');
    }

    toggle?.addEventListener('click', () => {
      if (sidebar?.classList.contains('open')) {
        closeSidebar();
      } else {
        openSidebar();
      }
    });

    overlay?.addEventListener('click', closeSidebar);

    // --- Update active link on navigation ---
    const currentPath = window.location.pathname.replace(/\/$/, '');
    document.querySelectorAll('#sidebar .lh-sidebar-link').forEach(link => {
      const href = (link as HTMLAnchorElement).getAttribute('href')?.replace(/\/$/, '') || '';
      if (href === currentPath) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });

    // --- Collapsible groups (only bind if not already bound) ---
    function setupCollapsible(selector: string) {
      document.querySelectorAll(selector).forEach(title => {
        if ((title as any)._lhBound) return;
        (title as any)._lhBound = true;

        title.addEventListener('click', () => {
          const items = title.nextElementSibling as HTMLElement;
          const arrow = title.querySelector('.lh-sidebar-arrow');
          if (!items) return;
          const isCollapsed = items.classList.contains('collapsed');
          items.classList.toggle('collapsed');
          arrow?.classList.toggle('collapsed');
          title.setAttribute('data-collapsed', isCollapsed ? 'false' : 'true');
        });
      });
    }

    setupCollapsible('.lh-sidebar-group-title');
    setupCollapsible('.lh-sidebar-subgroup-title');
  }

  document.addEventListener('astro:page-load', initSidebar);
</script>
