---
import '../styles/home.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatWidget from '../components/chat/ChatWidget.tsx';
import RecentSection from '../components/RecentSection.tsx';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const cardBackgrounds = [
  'bg1.png', 'bg2.png', 'bg3.jpg', 'bg4.webp', 'bg5.png', 'bg6.png', 'bg7.jpg', 'bg8.jpg', 'bg9.png', 'bg10.jpg',
  'bg11.png', 'bg12.png', 'bg13.png', 'bg14.png', 'bg15.png', 'bg16.png', 'bg17.png', 'bg18.png', 'bg19.png', 'bg20.png',
  'bg21.png', 'bg22.png', 'bg23.png', 'bg24.png', 'bg25.png', 'bg26.png', 'bg27.png', 'bg28.png', 'bg29.png', 'bg30.png',
  'bg31.png', 'bg32.png', 'bg33.png', 'bg34.png', 'bg35.png', 'bg36.png', 'bg37.png', 'bg38.png', 'bg39.png', 'bg40.png',
  'bg41.png', 'bg42.png', 'bg43.png', 'bg44.png', 'bg45.png', 'bg46.png', 'bg47.png', 'bg48.png', 'bg49.png', 'bg50.png',
  'bg51.png', 'bg52.png', 'bg53.png', 'bg54.png', 'bg55.png', 'bg56.png', 'bg57.png', 'bg58.png', 'bg59.png', 'bg60.png',
  'bg61.png', 'bg62.png', 'bg63.png', 'bg64.png', 'bg65.png',
];

const productCards = [
  {
    category: 'AI 产品',
    href: `${base}/ai-product-analysis/`,
    linkTitle: '查看 AI Research',
    title: 'AI Research',
    bg: 'bg45.png',
    description:
      '聚焦模型公司官方公告、LLM/Agent 论文与 Agent 生态热点，持续追踪 AI 前沿。News 栏目（原每日播报）每 12 小时更新一期，每一期都作为该栏目下一篇文章发布，并以时间作为标题。',
  },
  {
    category: '游戏开发',
    href: `${base}/unity-tutorial/`,
    linkTitle: '查看 Unity 教程',
    title: 'Unity',
    bg: 'bg20.png',
    description:
      '聚焦 3D 开放世界手游开发路径，从安装到核心系统实现，完整覆盖开发链路。角色控制、战斗、任务、地形、优化与发布全覆盖，适合前端背景开发者迁移学习。',
  },
  {
    category: '桌面开发',
    href: `${base}/electron-tutorial/`,
    linkTitle: '查看 Electron 教程',
    title: 'Electron',
    bg: 'bg30.png',
    description:
      '从基础能力到工程化落地，讲清进程模型、窗口管理、数据存储和打包发布。覆盖热更新与 OpenClaw 桌面端实战，帮助你搭建可维护、可迭代的桌面应用体系。',
  },
  {
    category: '实战案例',
    href: `${base}/rust-tutorial/`,
    linkTitle: '查看 Rust 教程',
    title: 'Rust',
    bg: 'bg55.png',
    description:
      '面向 TS/JS 开发者的 Rust 系统化学习路径：所有权、借用、并发、异步、宏与工程实战全覆盖。从语言基础到 Axum/WASM/FFI/Tokio 深入，帮助你构建高性能、可维护、可部署的 Rust 项目体系。',
  },
];

const allDocs = await getCollection('docs');

// News entries (up to 6 to ensure we can fill the grid)
const newsEntries = allDocs
  .filter(e => e.id.startsWith('ai-product-analysis/news/') && !e.id.endsWith('index.md'))
  .map(e => {
    const m = e.body?.match(/^#\s+(.+)$/m);
    const fullTitle = m?.[1]?.replace(/[*_`[\]]/g, '') ?? '';
    const parts = fullTitle.split('｜');
    const dateStr = parts[0]?.match(/(\d{2}-\d{2})/)?.[1] ?? '';
    const newsTitle = parts[1] ?? fullTitle;
    const desc = e.data?.description ?? '';
    const slug = e.id.replace(/\.md$/, '');
    return {
      slug,
      date: dateStr,
      title: newsTitle,
      description: desc.length > 100 ? desc.slice(0, 100) + '…' : desc,
      bg: '', // assigned after sort
    };
  })
  .sort((a, b) => b.slug.localeCompare(a.slug))
  .slice(0, 6)
  .map((item, i) => ({ ...item, bg: cardBackgrounds[i % cardBackgrounds.length] }));
---

<BaseLayout title="LightHouse" pageClass="lh-page-home">
  <main class="lh-main">
    <div class="lh-main-content">
      <div class="lh-landing">
        <section class="lh-intro">
          <h1>嗨！这里是 LightHouse</h1>
          <h2>从 BellLab 出发，记录面向 AI 时代的工程实践</h2>
          <p>LightHouse 是 BellLab 的学习与方法论分支。BellLab 这个名字致敬贝尔实验室——一个把科学突破、工程实现和长期主义放在一起的地方。这里不做"教程堆砌"，而是持续沉淀一套可复用的工作方式：如何和 AI 协作、如何把想法快速做成产品、如何在复杂系统里做正确的技术决策。</p>
          <p>当前聚焦四条主线：Unity 3D、Electron、Rust 与 AI 产品分析。Unity 关注交互与世界构建，Electron 聚焦桌面端产品化与工程稳定性，Rust 覆盖系统级性能与可靠性，AI 产品分析则用工程视角拆解产品。后续还会加入更多 AI 应用开发、自动化与系统设计专题。</p>
        </section>
        <RecentSection
          client:only="react"
          base={base}
          newsItems={newsEntries}
          backgrounds={cardBackgrounds}
        />
        <section class="lh-products">
          <div class="lh-products-head">
            <h3>AI 时代的构建模块</h3>
            <p>在 AI 驱动的软件范式里，能力不再只来自代码量，而来自模型协作、系统设计与持续迭代。</p>
          </div>
          <div class="lh-tabs">
            <span class="active" data-cat="">全部</span>
            <span data-cat="游戏开发">游戏开发</span>
            <span data-cat="桌面开发">桌面开发</span>
            <span data-cat="实战案例">实战案例</span>
            <span data-cat="AI 产品">AI 产品</span>
          </div>
          <div class="lh-home-grid">
            {productCards.map((card, index) => (
              <a
                class="lh-card group"
                data-category={card.category}
                href={card.href}
                title={card.linkTitle}
                style={`--lh-card-bg: url('${base}/card-bg/${card.bg ?? cardBackgrounds[index % cardBackgrounds.length]}')`}
              >
                <div class="lh-card-hero">
                  <h3>{card.title}</h3>
                </div>
                <div class="lh-desc">
                  <h4>{card.description}</h4>
                </div>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </main>
  <ChatWidget client:only="react" />
</BaseLayout>

<script>
  function initTabs() {
    const tabs = document.querySelectorAll<HTMLElement>('.lh-tabs span');
    const cards = document.querySelectorAll<HTMLElement>('.lh-card');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const cat = tab.dataset.cat;
        cards.forEach(card => {
          card.style.display = (!cat || card.dataset.category === cat) ? '' : 'none';
        });
      });
    });
  }
  initTabs();
  document.addEventListener('astro:page-load', initTabs);
</script>
