---
import '../styles/home.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatWidget from '../components/chat/ChatWidget.tsx';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sectionLabel: Record<string, string> = {
  'unity-tutorial': 'Unity',
  'electron-tutorial': 'Electron',
  'rust-tutorial': 'Rust',
  'ai-product-analysis': 'AI 研究',
};

const allDocs = await getCollection('docs');
const articles = allDocs
  .filter(e => !e.slug.split('/').pop()?.startsWith('index'))
  .map(e => {
    const m = e.body.match(/^#\s+(.+)$/m);
    const title = m?.[1]?.replace(/[*_`[\]]/g, '') ?? e.slug.split('/').pop()!;
    const section = e.slug.split('/')[0];
    return { slug: e.slug, title, label: sectionLabel[section] ?? section };
  })
  .sort((a, b) => b.slug.localeCompare(a.slug))
  .slice(0, 9);
---

<BaseLayout title="LightHouse" pageClass="lh-page-home">
  <main class="lh-main">
    <div class="lh-main-content">
      <div class="lh-landing">
        <section class="lh-intro">
          <h1>嗨！这里是 LightHouse</h1>
          <h2>从 BellLab 出发，记录面向 AI 时代的工程实践</h2>
          <p>LightHouse 是 BellLab 的学习与方法论分支。BellLab 这个名字致敬贝尔实验室——一个把科学突破、工程实现和长期主义放在一起的地方。这里不做"教程堆砌"，而是持续沉淀一套可复用的工作方式：如何和 AI 协作、如何把想法快速做成产品、如何在复杂系统里做正确的技术决策。</p>
          <p>当前聚焦四条主线：Unity 3D、Electron、Rust 与 AI 产品分析。Unity 关注交互与世界构建，Electron 聚焦桌面端产品化与工程稳定性，Rust 覆盖系统级性能与可靠性，AI 产品分析则用工程视角拆解产品。后续还会加入更多 AI 应用开发、自动化与系统设计专题。</p>
        </section>
        <section class="lh-products">
          <div class="lh-products-head">
            <h3>AI 时代的构建模块</h3>
            <p>在 AI 驱动的软件范式里，能力不再只来自代码量，而来自模型协作、系统设计与持续迭代。</p>
          </div>
          <div class="lh-tabs">
            <span class="active" data-cat="">全部</span>
            <span data-cat="游戏开发">游戏开发</span>
            <span data-cat="桌面开发">桌面开发</span>
            <span data-cat="实战案例">实战案例</span>
            <span data-cat="AI 产品">AI 产品</span>
          </div>
          <div class="lh-home-grid">
            <a class="lh-card group" data-category="游戏开发" href={`${base}/unity-tutorial/`} title="查看 Unity 教程">
              <div class="lh-card-media"><div class="lh-media-inner"><img src={`${base}/unity-logo.svg`} alt="Unity 3D" /></div></div>
              <h3>Unity 3D 从零到精通</h3>
              <div class="lh-desc">
                <h4>聚焦 3D 开放世界手游开发路径，从安装到核心系统实现，完整覆盖开发链路。</h4>
                <h4>角色控制、战斗、任务、地形、优化与发布全覆盖，适合前端背景开发者迁移学习。</h4>
              </div>
            </a>
            <a class="lh-card group" data-category="桌面开发" href={`${base}/electron-tutorial/`} title="查看 Electron 教程">
              <div class="lh-card-media"><div class="lh-media-inner"><img src={`${base}/electron-logo.svg`} alt="Electron" /></div></div>
              <h3>Electron 桌面开发</h3>
              <div class="lh-desc">
                <h4>从基础能力到工程化落地，讲清进程模型、窗口管理、数据存储和打包发布。</h4>
                <h4>覆盖热更新与 OpenClaw 桌面端实战，帮助你搭建可维护、可迭代的桌面应用体系。</h4>
              </div>
            </a>
            <a class="lh-card group" data-category="实战案例" href={`${base}/rust-tutorial/`} title="查看 Rust 教程">
              <div class="lh-card-media"><div class="lh-media-inner"><img src={`${base}/rust-logo.png`} alt="Rust" /></div></div>
              <h3>Rust 从入门到精通</h3>
              <div class="lh-desc">
                <h4>面向 TS/JS 开发者的 Rust 系统化学习路径：所有权、借用、并发、异步、宏与工程实战全覆盖。</h4>
                <h4>从语言基础到 Axum/WASM/FFI/Tokio 深入，帮助你构建高性能、可维护、可部署的 Rust 项目体系。</h4>
              </div>
            </a>
            <a class="lh-card group" data-category="AI 产品" href={`${base}/ai-product-analysis/`} title="查看 AI 研究">
              <div class="lh-card-media"><div class="lh-media-inner"><img src={`${base}/ai-analysis-logo.svg`} alt="AI 研究" /></div></div>
              <h3>AI 研究</h3>
              <div class="lh-desc">
                <h4>聚焦模型公司官方公告、LLM/Agent 论文、Agent 生态热点，持续追踪 AI 前沿。</h4>
                <h4>新增「每日播报」栏目，每 12 小时更新一期，沉淀到知识库，长期可回看。</h4>
              </div>
            </a>
            <a class="lh-card group" data-category="AI 产品" href={`${base}/ai-product-analysis/daily-broadcast`} title="查看 每日播报">
              <div class="lh-card-media"><div class="lh-media-inner"><img src={`${base}/ai-analysis-logo.svg`} alt="每日播报" /></div></div>
              <h3>每日播报（12h 一期）</h3>
              <div class="lh-desc">
                <h4>每 12 小时自动更新：官方公告、论文快讯、Agent 热点三段式简报。</h4>
                <h4>每条都保留来源链接与时间信息，方便快速浏览与后续深挖。</h4>
              </div>
            </a>
          </div>
        </section>
        <section class="lh-recent">
          <div class="lh-recent-head">
            <h3>最近更新</h3>
          </div>
          <div class="lh-recent-grid">
            {articles.map(a => (
              <a class="lh-recent-card" href={`${base}/${a.slug}/`}>
                <span class="lh-recent-tag">{a.label}</span>
                <p class="lh-recent-title">{a.title}</p>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </main>
  <ChatWidget client:only="react" />
</BaseLayout>

<script>
  function initTabs() {
    const tabs = document.querySelectorAll<HTMLElement>('.lh-tabs span');
    const cards = document.querySelectorAll<HTMLElement>('.lh-card');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const cat = tab.dataset.cat;
        cards.forEach(card => {
          card.style.display = (!cat || card.dataset.category === cat) ? '' : 'none';
        });
      });
    });
  }
  initTabs();
  document.addEventListener('astro:page-load', initTabs);
</script>
