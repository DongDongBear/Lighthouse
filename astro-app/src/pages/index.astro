---
import '../styles/home.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatWidget from '../components/chat/ChatWidget.tsx';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sectionLabel: Record<string, string> = {
  'unity-tutorial': 'Unity',
  'electron-tutorial': 'Electron',
  'rust-tutorial': 'Rust',
  'ai-product-analysis': 'AI 研究',
};

const cardBackgrounds = ['bg1.png', 'bg2.png', 'bg3.jpg', 'bg4.webp', 'bg5.png', 'bg6.png'];

const productCards = [
  {
    category: 'AI 产品',
    href: `${base}/ai-product-analysis/`,
    linkTitle: '查看 AI Research',
    title: 'AI Research',
    bg: 'bg7.jpg',
    description: [
      '聚焦模型公司官方公告、LLM/Agent 论文与 Agent 生态热点，持续追踪 AI 前沿。',
      'New 栏目（原每日播报）每 12 小时更新一期，每一期都作为该栏目下一篇文章发布，并以时间作为标题。',
    ],
  },
  {
    category: '游戏开发',
    href: `${base}/unity-tutorial/`,
    linkTitle: '查看 Unity 教程',
    title: 'Unity',
    description: [
      '聚焦 3D 开放世界手游开发路径，从安装到核心系统实现，完整覆盖开发链路。',
      '角色控制、战斗、任务、地形、优化与发布全覆盖，适合前端背景开发者迁移学习。',
    ],
  },
  {
    category: '桌面开发',
    href: `${base}/electron-tutorial/`,
    linkTitle: '查看 Electron 教程',
    title: 'Electron',
    description: [
      '从基础能力到工程化落地，讲清进程模型、窗口管理、数据存储和打包发布。',
      '覆盖热更新与 OpenClaw 桌面端实战，帮助你搭建可维护、可迭代的桌面应用体系。',
    ],
  },
  {
    category: '实战案例',
    href: `${base}/rust-tutorial/`,
    linkTitle: '查看 Rust 教程',
    title: 'Rust',
    description: [
      '面向 TS/JS 开发者的 Rust 系统化学习路径：所有权、借用、并发、异步、宏与工程实战全覆盖。',
      '从语言基础到 Axum/WASM/FFI/Tokio 深入，帮助你构建高性能、可维护、可部署的 Rust 项目体系。',
    ],
  },
];

const allDocs = await getCollection('docs');
const articles = allDocs
  .filter(e => !e.slug.split('/').pop()?.startsWith('index'))
  .map(e => {
    const m = e.body.match(/^#\s+(.+)$/m);
    const title = m?.[1]?.replace(/[*_`[\]]/g, '') ?? e.slug.split('/').pop()!;
    const section = e.slug.split('/')[0];
    return { slug: e.slug, title, label: sectionLabel[section] ?? section };
  })
  .sort((a, b) => b.slug.localeCompare(a.slug))
  .slice(0, 9);
---

<BaseLayout title="LightHouse" pageClass="lh-page-home">
  <main class="lh-main">
    <div class="lh-main-content">
      <div class="lh-landing">
        <section class="lh-intro">
          <h1>嗨！这里是 LightHouse</h1>
          <h2>从 BellLab 出发，记录面向 AI 时代的工程实践</h2>
          <p>LightHouse 是 BellLab 的学习与方法论分支。BellLab 这个名字致敬贝尔实验室——一个把科学突破、工程实现和长期主义放在一起的地方。这里不做"教程堆砌"，而是持续沉淀一套可复用的工作方式：如何和 AI 协作、如何把想法快速做成产品、如何在复杂系统里做正确的技术决策。</p>
          <p>当前聚焦四条主线：Unity 3D、Electron、Rust 与 AI 产品分析。Unity 关注交互与世界构建，Electron 聚焦桌面端产品化与工程稳定性，Rust 覆盖系统级性能与可靠性，AI 产品分析则用工程视角拆解产品。后续还会加入更多 AI 应用开发、自动化与系统设计专题。</p>
        </section>
        <section class="lh-products">
          <div class="lh-products-head">
            <h3>AI 时代的构建模块</h3>
            <p>在 AI 驱动的软件范式里，能力不再只来自代码量，而来自模型协作、系统设计与持续迭代。</p>
          </div>
          <div class="lh-tabs">
            <span class="active" data-cat="">全部</span>
            <span data-cat="游戏开发">游戏开发</span>
            <span data-cat="桌面开发">桌面开发</span>
            <span data-cat="实战案例">实战案例</span>
            <span data-cat="AI 产品">AI 产品</span>
          </div>
          <div class="lh-home-grid">
            {productCards.map((card, index) => (
              <a
                class="lh-card group"
                data-category={card.category}
                href={card.href}
                title={card.linkTitle}
                style={`--lh-card-bg: url('${base}/card-bg/${card.bg ?? cardBackgrounds[index % cardBackgrounds.length]}')`}
              >
                <div class="lh-card-hero">
                  <h3>{card.title}</h3>
                </div>
                <div class="lh-desc">
                  {card.description.map(line => (
                    <h4>{line}</h4>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </section>
        <section class="lh-recent">
          <div class="lh-recent-head">
            <h3>最近更新</h3>
          </div>
          <div class="lh-recent-grid">
            {articles.map((a, index) => (
              <a
                class="lh-recent-card"
                href={`${base}/${a.slug}/`}
                style={`--lh-card-bg: url('${base}/card-bg/${cardBackgrounds[index % cardBackgrounds.length]}')`}
              >
                <span class="lh-recent-tag">{a.label}</span>
                <p class="lh-recent-title">{a.title}</p>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </main>
  <ChatWidget client:only="react" />
</BaseLayout>

<script>
  function initTabs() {
    const tabs = document.querySelectorAll<HTMLElement>('.lh-tabs span');
    const cards = document.querySelectorAll<HTMLElement>('.lh-card');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const cat = tab.dataset.cat;
        cards.forEach(card => {
          card.style.display = (!cat || card.dataset.category === cat) ? '' : 'none';
        });
      });
    });
  }
  initTabs();
  document.addEventListener('astro:page-load', initTabs);
</script>
