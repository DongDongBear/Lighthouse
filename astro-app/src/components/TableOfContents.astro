---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const toc = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{toc.length > 0 && (
  <div class="lh-toc">
    <div class="lh-toc-title">目录</div>
    <ul class="lh-toc-list">
      {toc.map(h => (
        <li class={`lh-toc-item depth-${h.depth}`}>
          <a href={`#${h.slug}`} class="lh-toc-link">{h.text}</a>
        </li>
      ))}
    </ul>
  </div>
)}

<style>
  .lh-toc {
    font-family: var(--vp-font-family-base);
  }

  .lh-toc-title {
    font-size: 13px;
    letter-spacing: .04em;
    color: var(--vp-c-text-1);
    font-weight: 500;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--vp-c-divider-light);
  }

  .lh-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .lh-toc-item.depth-3 {
    padding-left: 14px;
  }

  .lh-toc-link {
    display: block;
    padding: 5px 0;
    font-size: 13px;
    line-height: 1.5;
    color: var(--vp-c-text-3);
    text-decoration: none;
    transition: color .15s ease;
    font-weight: 400;
  }

  .lh-toc-link:hover {
    color: var(--vp-c-text-1);
  }
</style>
