---
import '../styles/doc.css';
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import DocFooter from '../components/DocFooter.astro';
import ChatWidget from '../components/chat/ChatWidget.tsx';
import { getSidebarGroups } from '../data/sidebar';

interface Props {
  title?: string;
  headings?: { depth: number; slug: string; text: string }[];
  slug?: string;
}

const { title = 'LightHouse', headings = [], slug = '' } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sidebarGroups = getSidebarGroups(currentPath.replace(base, ''));
const hasSidebar = sidebarGroups !== null && sidebarGroups.length > 0;
const articleHeroBgs = ['bg1.png', 'bg2.png', 'bg3.jpg', 'bg4.webp', 'bg5.png', 'bg6.png', 'bg7.jpg', 'bg8.jpg', 'bg9.png', 'bg10.jpg'];
const initialHeroBg = articleHeroBgs[Math.floor(Math.random() * articleHeroBgs.length)];
const cleanSlug = slug.replace(/\.md$/, '');
const heroLabel = (() => {
  if (cleanSlug.startsWith('ai-product-analysis/news/')) return 'News';
  if (cleanSlug.startsWith('ai-product-analysis/')) return 'AI 产品分析';
  if (cleanSlug.startsWith('ai-research/')) return 'AI Research';
  if (cleanSlug.startsWith('unity-tutorial/')) return 'Unity';
  if (cleanSlug.startsWith('electron-tutorial/')) return 'Electron';
  if (cleanSlug.startsWith('rust-tutorial/')) return 'Rust';
  return 'LightHouse';
})();
---

<BaseLayout title={title} pageClass={`lh-page-doc${hasSidebar ? ' has-sidebar' : ''}`}>
  <main class="lh-main">
    {hasSidebar && sidebarGroups && (
      <Sidebar groups={sidebarGroups} currentPath={currentPath} />
    )}
    <div class="lh-main-content">
      <article class="lh-prose">
        <div class="lh-article-hero" style={`--lh-article-hero-bg: url('${base}/card-bg/${initialHeroBg}')`}>
          <div class="lh-article-hero-inner">
            <p class="lh-article-hero-kicker">{heroLabel}</p>
            <h1 class="lh-article-hero-title">{title}</h1>
          </div>
        </div>
        <slot />
      </article>
      <DocFooter currentPath={currentPath} />
    </div>
    {headings.length > 0 && (
      <div class="lh-toc-wrap">
        <TableOfContents headings={headings} />
      </div>
    )}
  </main>
  <ChatWidget client:only="react" />
</BaseLayout>

<script is:inline>
  (() => {
    const heroImages = ['bg1.png', 'bg2.png', 'bg3.jpg', 'bg4.webp', 'bg5.png', 'bg6.png', 'bg7.jpg', 'bg8.jpg', 'bg9.png', 'bg10.jpg'];
    const base = {JSON.stringify(base)};

    const applyRandomHero = () => {
      const hero = document.querySelector('.lh-article-hero');
      if (!hero) return;
      const randomImage = heroImages[Math.floor(Math.random() * heroImages.length)];
      hero.style.setProperty('--lh-article-hero-bg', `url('${base}/card-bg/${randomImage}')`);
    };

    applyRandomHero();

    if (!window.__lhArticleHeroRandomInited) {
      document.addEventListener('astro:page-load', applyRandomHero);
      window.__lhArticleHeroRandomInited = true;
    }
  })();
</script>
